# ─── Obelisk Q: Frontend Environment Configuration ──────────────────────────
# Copy this file to .env.local for development

# The deployed ObeliskVault address on Mantle Network
VITE_VAULT_ADDRESS=0x...

# The Mantle Network RPC URL (Public or Private)
VITE_RPC_URL=https://rpc.mantle.xyz

# The Obelisk Q Backend API Endpoint
VITE_API_ENDPOINT=http://localhost:8000

# ⚠️ SECURITY WARNING: 
# Any variable starting with VITE_ will be bundled into the production JS.
# NEVER put private keys or sensitive credentials in this file.
