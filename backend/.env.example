# ─── Obelisk Q — Environment Variables Template ─────────────────────────────
# Copy this file to backend/.env and fill in your values.
# NEVER commit your real .env file to version control.

# ─── LLM Provider (Azure OpenAI — Primary) ────────────────────────────────────
# Get these from: https://portal.azure.com > Azure OpenAI resource
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com/openai/v1
AZURE_OPENAI_API_VERSION=v:2024-07-18
AZURE_OPENAI_CHAT_DEPLOYMENT_NAME=gpt-4o-mini

# ─── Mantle Network ───────────────────────────────────────────────────────────
# Primary RPC (use QuikNode/Alchemy for production, public RPC for testing):
MANTLE_RPC_URL=https://rpc.mantle.xyz
# Comma-separated fallback RPCs (multi-RPC failover):
MANTLE_RPC_URLS=https://rpc.mantle.xyz,https://mantle.publicnode.com,https://mantle-mainnet.public.blastapi.io

# ─── Agent Wallet ─────────────────────────────────────────────────────────────
# CRITICAL: Use a dedicated throwaway wallet for the agent — NEVER your personal wallet.
# This wallet needs a small amount of MNT for gas (~0.1 MNT is sufficient for testing).
AGENT_PRIVATE_KEY=your_agent_wallet_private_key_here

# ─── Vault Contract ───────────────────────────────────────────────────────────
# Deployed ObeliskVault contract address on Mantle Mainnet:
VAULT_ADDRESS=0xE7F15F0FBaF7f928AC42D7352BBF68E9Ab94c6DD
# Frontend also needs the vault address:
VITE_VAULT_ADDRESS=0xE7F15F0FBaF7f928AC42D7352BBF68E9Ab94c6DD
ZK_VERIFIER_ADDRESS=0x2319ae743dF01506eAd1Fbc9398780885cCeF60d

# ─── External APIs (Optional but Recommended) ─────────────────────────────────
# CoinGecko API Key (free tier works; improves MNT price data reliability):
# Get at: https://www.coingecko.com/en/api
COINGECKO_API_KEY=your_coingecko_api_key_here

# ─── Redis (Optional — for multi-node HA mode) ────────────────────────────────
# Leave as default for single-node local development:
REDIS_URL=redis://localhost:6379

# ─── Agent Tuning (Optional — safe to leave as defaults) ──────────────────────
NODE_ID=local
AGENT_RPC_TIMEOUT=20
AGENT_CYCLE_TIMEOUT=90
MAX_RPC_ATTEMPTS=5
BACKOFF_FACTOR=1.0

# ─── Local LLM Fallback (Optional — if Azure is not available) ────────────────
# Runs Ollama locally with a compatible model (e.g., llama3):
LLM_API_BASE=http://localhost:11434/v1
