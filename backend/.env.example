# Obelisk Q — Environment Configuration Template

# ─── LLM / AI Configuration ───
AZURE_OPENAI_API_KEY=your_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_CHAT_DEPLOYMENT_NAME=gpt-4o
# Optional: Local LLM Fallback (Ollama/vLLM)
LLM_API_BASE=http://localhost:11434/v1

# ─── External Data Providers ───
COINGECKO_API_KEY=your_coingecko_key  # Required for Mantle price feeds
DEFILLAMA_API_KEY=optional_key        # For yield vector telemetry
# Fear & Greed Index (Public API)

# ─── Mantle Network Configuration ───
# Multi-RPC Failover: Provide comma-separated URLs
MANTLE_RPC_URLS=https://rpc.mantle.xyz,https://mantle.publicnode.com,https://rpc.ankr.com/mantle
AGENT_PRIVATE_KEY=0x...
VAULT_ADDRESS=0x...

# ─── Antigravity HA & SLA ───
NODE_ROLE=primary        # primary | shadow
NODE_ID=vm-node-1        # unique identifier
AGENT_RPC_TIMEOUT=15     # Max seconds per RPC call
AGENT_CYCLE_TIMEOUT=45   # Max seconds per analysis cycle
MAX_RPC_ATTEMPTS=3       # Max retries per cycle (cycles through RPC_URLS)
ERROR_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ─── Frontend Compatibility ───
VITE_VAULT_ADDRESS=0x...
