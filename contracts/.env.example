# Obelisk Q — Smart Contract Development Environment
# Rename this file to .env for Hardhat deployments

# ─── Wallet Configuration ───
# MANDATORY: Private key of the deployer account (WITHOUT 0x prefix)
PRIVATE_KEY=your_private_key_without_0x_prefix_here

# ─── Network Endpoints ───
MANTLE_RPC_URL=https://rpc.mantle.xyz
MANTLE_TESTNET_RPC_URL=https://rpc.testnet.mantle.xyz

# ─── Contract Verification ───
# API Key from Mantle Explorer (if applicable)
MANTLESCAN_API_KEY=your_explorer_api_key_here

# ─── Deployed Addresses ───
# Populated after 'npx hardhat run scripts/deploy.js --network mantle'
VAULT_ADDRESS=your_deployed_vault_address_here
MNT_TOKEN_ADDRESS=0x78c1b0C116c6f645083763Ad078202d03920a1E3
USDC_TOKEN_ADDRESS=0x09bc2e5a4a717d88be1ec5a4521f1d5e32230103
