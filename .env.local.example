# Obelisk Q — Frontend Environment Template
# Rename this file to .env.local for development

# ─── Contract Addresses ───
VITE_VAULT_ADDRESS=your_deployed_vault_address_here

# ─── Network Configuration ───
VITE_RPC_URL=https://rpc.mantle.xyz
VITE_CHAIN_ID=5000

# ─── Telemetry & API ───
# Point to your Azure VM or local backend
VITE_AGENT_API_URL=http://localhost:8000
VITE_WEBSOCKET_URL=ws://localhost:8000/ws/agent

# ─── Third Party Keys (Optional) ───
VITE_WALLETCONNECT_PROJECT_ID=your_project_id_from_reown
